bin "vm-boot"
about "Boot an ISO file in a VM with automatic architecture detection"

flag "-m --memory <size>" help="Memory in MB (default: 2048)"
flag "-c --cpus <count>" help="Number of CPU cores (default: 2)"
flag "-a --arch <arch>" help="Force architecture (x86_64 or aarch64)"
flag "-n --nographic" help="Run in text mode without graphics"
flag "-h --help" help="Show help message"

arg "<iso_file>" help="ISO file to boot"
